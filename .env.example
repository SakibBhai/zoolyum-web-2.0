# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# NextAuth Configuration
NEXTAUTH_URL="https://zoolyum-web-20.vercel.app"
NEXTAUTH_SECRET="PF/eiM/WrVsJpy/saru38Jvctf849ppUq6YcAQIDfIY="

# Node Environment
NODE_ENV="development"

# Vercel Blob Storage (Required for image uploads)
# Get this from: Vercel Dashboard → Storage → Blob Store → Settings → Environment Variables
BLOB_READ_WRITE_TOKEN="vercel_blob_w_your_token_here"

# Optional: Vercel API Token for advanced Blob operations (list, delete by API)
# Get this from: https://vercel.com/account/tokens
# VERCEL_TOKEN="your_vercel_api_token"

# OAuth Providers (Optional - for NextAuth)
# Google OAuth
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# AWS S3 / Cloudflare R2 Configuration (Optional - for file uploads)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# R2_ACCOUNT_ID="your-r2-account-id"
# R2_ACCESS_KEY_ID="your-r2-access-key"
# R2_SECRET_ACCESS_KEY="your-r2-secret-key"
# R2_BUCKET_NAME="your-bucket-name"
# R2_PUBLIC_URL="https://your-bucket.r2.dev"

# Resend Email Configuration (Optional - for email notifications)
# RESEND_API_KEY="your-resend-api-key"
# RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Application URLs (Auto-set in production)
NEXT_PUBLIC_APP_URL="https://zoolyum-web-20.vercel.app"
NEXT_PUBLIC_API_URL="https://zoolyum-web-20.vercel.app/api"
NEXT_PUBLIC_BASE_URL="https://zoolyum-web-20.vercel.app"
